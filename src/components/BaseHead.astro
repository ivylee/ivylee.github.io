---
import { Schema } from 'astro-seo-schema';
import { Seo } from 'astro-seo-meta';
import siteConfig from '../data/site-config';
import { buildSeoGraph } from '../utils/seo-schema';
import '../styles/global.css';

export type Props = {
    title?: string;
    description?: string;
    image?: { src: string; alt?: string };
    pageType?: 'website' | 'article';
    schemaKind?: 'webpage' | 'profile' | 'collection' | 'blog' | 'blogPost' | 'project';
    publishedDate?: Date | string;
    updatedDate?: Date | string;
    tags?: string[];
    breadcrumbs?: { name: string; url: string }[];
    projectUrl?: string;
};

const {
    description = siteConfig.description,
    image = siteConfig.image,
    pageType = 'website',
    schemaKind = 'webpage',
    publishedDate,
    updatedDate,
    tags,
    breadcrumbs,
    projectUrl
} = Astro.props;
const title = [Astro.props.title, siteConfig.title].filter(Boolean).join(' | ');
const resolvedImage = image?.src
    ? {
          src: new URL(image.src, Astro.site).toString(),
          alt: image.alt
      }
    : undefined;
const canonicalURL = new URL(Astro.request.url, Astro.site);

/**
 * Enforce some standard canonical URL formatting across the site.
 */
function formatCanonicalURL(url: string | URL) {
    const path = url.toString();
    const hasQueryParams = path.includes('?');
    // If there are query params, make sure the URL has no trailing slash
    if (hasQueryParams) {
        path.replace(/\/?$/, '');
    }
    // otherwise, canonical URL always has a trailing slash
    return path.replace(/\/?$/, hasQueryParams ? '' : '/');
}

const canonicalHref = formatCanonicalURL(canonicalURL);
const seoGraph = buildSeoGraph({
    canonicalUrl: canonicalHref,
    title,
    description,
    image,
    kind: schemaKind,
    publishedDate,
    updatedDate,
    tags,
    breadcrumbs,
    projectUrl
});
---

<!-- High Priority Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400..700&family=Lora:ital,wght@0,400..700;1,400..700&display=swap"
    rel="stylesheet"
/>

<!-- Low Priority Global Metadata -->
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" href="/rss.xml" title="RSS" />

<!-- Page Metadata -->
<link rel="canonical" href={canonicalHref} />
<Seo
    title={title}
    description={description}
    icon="/favicon.svg"
    facebook={{
        image: resolvedImage?.src,
        url: canonicalHref,
        type: pageType
    }}
    twitter={{
        image: resolvedImage?.src,
        card: 'summary_large_image'
    }}
/>
{resolvedImage?.alt && <meta property="og:image:alt" content={resolvedImage.alt} />}
<meta property="twitter:url" content={canonicalHref} />
{resolvedImage?.alt && <meta name="twitter:image:alt" content={resolvedImage?.alt} />}
<Schema item={seoGraph} />

<!-- Cloudflare Web Analytics -->
<script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "b795a838b6b34046b85a949ecb2e3e6a"}'></script>
<!-- End Cloudflare Web Analytics -->
